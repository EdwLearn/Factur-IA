# FacturIA Test Environment Configuration

# Environment
ENVIRONMENT=test

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000

# Database - Test Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=facturia_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=1

# AWS - Mocked with LocalStack
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=testing
AWS_SECRET_ACCESS_KEY=testing

# S3
S3_DOCUMENT_BUCKET=facturia-test-documents

# ML - Disabled for faster tests
ENABLE_ML_CACHE=false
ML_CLASSIFICATION_THRESHOLD=0.7

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=text

# Security - Test keys
SECRET_KEY=test-secret-key-not-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=5

# Feature Flags - Some disabled for testing
ENABLE_TEXTRACT=false  # Use mocks
ENABLE_ML_RECOMMENDATIONS=false
ENABLE_DUPLICATE_DETECTION=true
